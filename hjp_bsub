#!/bin/bash
# hjp_bsub v1.6
declare -A Q_NPROC Q_NTHR Q_NCPU Q_MARCH Q_NODE_PATTERN Q_THRESHOLD Q_TFLOPS
Q_NPROC[ocean_530_1day]=4;  Q_NTHR[ocean_530_1day]=6;  Q_NCPU[ocean_530_1day]=24;  Q_MARCH[ocean_530_1day]=skylake-avx512;  Q_NODE_PATTERN[ocean_530_1day]='^hd0(0[1-9]|1[0-9]|2[0-8]) '; Q_THRESHOLD[ocean_530_1day]=36;  Q_TFLOPS[ocean_530_1day]="79"
Q_NPROC[ocean6226R_1day]=4; Q_NTHR[ocean6226R_1day]=8;  Q_NCPU[ocean6226R_1day]=32; Q_MARCH[ocean6226R_1day]=cascadelake;    Q_NODE_PATTERN[ocean6226R_1day]='^hd0(29|3[0-9]|4[0-8]) ';   Q_THRESHOLD[ocean6226R_1day]=48; Q_TFLOPS[ocean6226R_1day]="129"
Q_NPROC[normal_1day_new]=4; Q_NTHR[normal_1day_new]=6;  Q_NCPU[normal_1day_new]=24; Q_MARCH[normal_1day_new]=skylake-avx512; Q_NODE_PATTERN[normal_1day_new]='^s0(0[6-9]|1[0-8]) ';        Q_THRESHOLD[normal_1day_new]=36; Q_TFLOPS[normal_1day_new]="79"
Q_NPROC[normal_1day]=4;     Q_NTHR[normal_1day]=7;      Q_NCPU[normal_1day]=28;     Q_MARCH[normal_1day]=broadwell;          Q_NODE_PATTERN[normal_1day]='^nxt0(0[1-9]|4[124-9]|5[0-9]|6[0-7]) ';                  Q_THRESHOLD[normal_1day]=42; Q_TFLOPS[normal_1day]="93"
Q_NPROC[normal_1week]=4;    Q_NTHR[normal_1week]=7;     Q_NCPU[normal_1week]=28;    Q_MARCH[normal_1week]=broadwell;         Q_NODE_PATTERN[normal_1week]='^nxt0(1[0-46-9]|2[0-9]|3[0-9]|40) ';          Q_THRESHOLD[normal_1week]=42; Q_TFLOPS[normal_1week]="93"
Q_NPROC[normal_2week]=8;    Q_NTHR[normal_2week]=6;     Q_NCPU[normal_2week]=48;    Q_MARCH[normal_2week]=icelake-server;    Q_NODE_PATTERN[normal_2week]='^b0(0[1-9]|1[0-4]) ';            Q_THRESHOLD[normal_2week]=72; Q_TFLOPS[normal_2week]="167"
Q_NPROC[normal]=4;          Q_NTHR[normal]=4;            Q_NCPU[normal]=20;          Q_MARCH[normal]=ivybridge;               Q_NODE_PATTERN[normal]='^c0(0[1-9]|19|2[013-9]|3[0-9]|4[0-8]) ';             Q_THRESHOLD[normal]=30;  Q_TFLOPS[normal]="29"
QUEUES=(ocean_530_1day ocean6226R_1day normal_1day_new normal_1day normal_1week normal_2week normal)
if [[ -t 1 ]]; then
  bold=$(tput bold 2>/dev/null||true); reset=$(tput sgr0 2>/dev/null||true)
  red=$(tput setaf 1 2>/dev/null||true); green=$(tput setaf 2 2>/dev/null||true)
  yellow=$(tput setaf 3 2>/dev/null||true); cyan=$(tput setaf 6 2>/dev/null||true)
  dim=$(tput dim 2>/dev/null||true)
else bold=;reset=;red=;green=;yellow=;cyan=;dim=; fi
declare -A Q_EMPTY Q_HALF Q_FULL Q_OVER
_LSLOAD_DATA="" _BHOSTS_DATA=""
fetch_cluster_data() {
  _LSLOAD_DATA=$(lsload -l 2>/dev/null)
  _BHOSTS_DATA=$(bhosts 2>/dev/null)
}
gather_stats() {
  local q pat thresh e h f o
  for q in "${QUEUES[@]}"; do
    pat="${Q_NODE_PATTERN[$q]}"; thresh="${Q_THRESHOLD[$q]}"
    read -r e h f o < <(awk -v pat="$pat" -v thresh="$thresh" '
      NR==FNR { if (FNR>1) load[$1]=$5+0; next }
      $0 ~ pat {
        host=$1; status=$2; maxj=$4+0; njobs=$5+0; r15m=load[host]+0
        if (status!="ok" || njobs>=maxj) o++
        else if (njobs==0) e++
        else if (njobs<=maxj/2) h++
        else f++
      }
      END { print e+0, h+0, f+0, o+0 }
    ' <(echo "$_LSLOAD_DATA") <(echo "$_BHOSTS_DATA"))
    Q_EMPTY[$q]=$e; Q_HALF[$q]=$h; Q_FULL[$q]=$f; Q_OVER[$q]=$o
  done
}
pick_queue() {
  local var_name="$1" i=1 q e h f o es hs fs os oc avail choice
  printf "\n${bold}Queue:${reset}\n"
  printf "  ${dim}%-3s  %-22s  %5s  %13s    %s${reset}\n" "No." "Name" "Cores" "Peak DP" "Node avail."
  printf "  ${dim}%s${reset}\n" "$(printf '─%.0s' {1..88})"
  for q in "${QUEUES[@]}"; do
    e=${Q_EMPTY[$q]}; h=${Q_HALF[$q]}; f=${Q_FULL[$q]}; o=${Q_OVER[$q]}
    es=$(printf "%2d" $e); hs=$(printf "%2d" $h); fs=$(printf "%2d" $f); os=$(printf "%2d" $o)
    if [[ $o -gt 0 ]]; then oc="$red"; else oc=""; fi
    avail="${green}idle:${es}${reset}  ${yellow}half:${hs}${reset}  ${red}full:${fs}${reset}  ${oc}over:${os}${reset}"
    printf "  ${bold}%2d)${reset}  %-22s  %4dc  %6s GFLOPS    %b\n" \
      "$i" "$q" "${Q_NCPU[$q]}" "${Q_TFLOPS[$q]}" "$avail"
    ((i++))
  done
  while true; do
    printf "\nSelect (1-%d): " "${#QUEUES[@]}"; read -r choice
    [[ "$choice" =~ ^[0-9]+$ ]] && ((choice>=1 && choice<=${#QUEUES[@]})) && break
    echo "  Invalid."
  done
  printf -v "$var_name" '%s' "${QUEUES[$((choice-1))]}"
}
pick() {
  local title="$1" var_name="$2"; shift 2
  local opts=("$@") i=1 choice o
  printf "\n${bold}%s${reset}\n" "$title"
  for o in "${opts[@]}"; do printf "  %d) %s\n" "$((i++))" "$o"; done
  while true; do
    printf "Select (1-%d): " "${#opts[@]}"; read -r choice
    [[ "$choice" =~ ^[0-9]+$ ]] && ((choice>=1 && choice<=${#opts[@]})) && break
    echo "  Invalid."
  done
  printf -v "$var_name" '%s' "${opts[$((choice-1))]}"
}
ask() {
  local prompt="$1" default="${2:-}" var_name="$3" reply
  printf "%s%s%s" "$bold" "$prompt" "$reset"
  [[ -n $default ]] && printf " [%s]" "$default"
  printf ": "; read -r reply
  printf -v "$var_name" '%s' "${reply:-$default}"
}
default_job_name() {
  python3 -c "import pathlib; p=pathlib.Path.cwd().parts; print(p[4]+'_'+p[-1] if len(p)>=6 else 'my-great-job')" 2>/dev/null || echo "my-great-job"
}
build_exclude_expr() {
  local expr="" n
  for n in "$@"; do expr+="${expr:+ && }hname!=${n}"; done
  [[ -n $expr ]] && echo "select[$expr]"
}
detect_bad_nodes() {
  local pat="$1" thresh="$2"
  awk -v pat="$pat" -v thresh="$thresh" '
    NR==FNR { if (FNR>1) load[$1]=$5+0; next }
    $0 ~ pat {
      host=$1; status=$2; njobs=$5+0; r15m=load[host]+0
      if (status != "ok") next
      if (r15m > thresh) { print host; next }
      if (r15m - njobs > 5) { print host; next }
    }
  ' <(echo "$_LSLOAD_DATA") <(echo "$_BHOSTS_DATA")
}
detect_orphan_nodes() {
  # Check idle nodes for orphaned prted daemons (HNP no longer alive).
  # Runs per-node checks in parallel to keep latency low.
  local pat="$1" tmpdir node
  tmpdir=$(mktemp -d)
  while read -r node; do
    {
      local info pid hnp_host hnp_pid result
      info=$(lsrun -m "$node" ps -ww -eo pid,cmd 2>/dev/null | awk '
        /prted/ && /ess_base_nspace/ {
          for(i=1;i<=NF;i++) if($i=="ess_base_nspace"){ns=$(i+1);break}
          if(!ns) next
          sub(/@.*/,"",ns); sub(/prterun-/,"",ns)
          n=split(ns,a,"-"); hnp_pid=a[n]; hnp_host=""
          for(j=1;j<n;j++) hnp_host=hnp_host(j>1?"-":"")a[j]
          print $1, hnp_host, hnp_pid; exit
        }
      ')
      [[ -z "$info" ]] && exit 0
      read -r pid hnp_host hnp_pid <<< "$info"
      [[ -z "$hnp_pid" ]] && exit 0
      result=$(lsrun -m "$hnp_host" ps -p "$hnp_pid" --no-headers -o pid 2>/dev/null)
      [[ $? -eq 0 && -z "$result" ]] && echo "$node" > "$tmpdir/$node"
    } &
  done < <(awk -v pat="$pat" 'NR>1 && $0~pat && $2=="ok" && $5+0==0 {print $1}' <(echo "$_BHOSTS_DATA"))
  wait
  cat "$tmpdir"/* 2>/dev/null
  rm -rf "$tmpdir"
}
printf "\n${bold}${cyan}╔══════════════════════════════╗\n║       hjp_bsub  v1.6         ║\n╚══════════════════════════════╝${reset}\n"
printf "${yellow}Gathering node statistics...${reset}"
fetch_cluster_data
gather_stats
printf "\r%-35s\r" ""
pick_queue QUEUE
NPROC_PER_NODE=${Q_NPROC[$QUEUE]}; NTHR=${Q_NTHR[$QUEUE]}; NCPU_PER_NODE=${Q_NCPU[$QUEUE]}
MARCH=${Q_MARCH[$QUEUE]}; NODE_PATTERN=${Q_NODE_PATTERN[$QUEUE]}; THRESHOLD=${Q_THRESHOLD[$QUEUE]}
pick "VASP variant:" VASP std gam ncl
printf "\n"
ask "Number of nodes" "1" NUM_NODES
if ! [[ "$NUM_NODES" =~ ^[1-9][0-9]*$ ]]; then printf "%sInvalid node count.%s\n" "$red" "$reset"; exit 1; fi
ask "Job name" "$(default_job_name)" JOB_NAME
ask "Output file" "output.txt" OUTPUT_FILE
printf "\n${yellow}Checking per-node load and orphaned prted...${reset}\n"
mapfile -t BAD_NODES < <({ detect_bad_nodes "$NODE_PATTERN" "$THRESHOLD"; detect_orphan_nodes "$NODE_PATTERN"; } | sort -u)
if [[ ${#BAD_NODES[@]} -eq 0 ]]; then
  printf "${green}No problematic nodes — no exclusions.${reset}\n"; EXCLUDE_EXPR=""
else
  printf "${red}Nodes excluded: %s${reset}\n" "${BAD_NODES[*]}"
  EXCLUDE_EXPR=$(build_exclude_expr "${BAD_NODES[@]}")
fi
TOTAL_SLOTS=$(( NUM_NODES * NCPU_PER_NODE ))
TOTAL_MPI=$(( NUM_NODES * NPROC_PER_NODE ))
if [[ "$NUM_NODES" -eq 1 ]]; then
  SPAN_EXPR="span[hosts=1]"
  MPIMAP="socket:PE=${NTHR}"
else
  SPAN_EXPR="span[ptile=${NCPU_PER_NODE}]"
  MPIMAP="ppr:${NPROC_PER_NODE}:node:PE=${NTHR}"
fi
R_EXPR="${EXCLUDE_EXPR:+${EXCLUDE_EXPR} }${SPAN_EXPR}"
JOB_NAME_Q=$(printf '%q' "$JOB_NAME"); OUTPUT_Q=$(printf '%q' "$OUTPUT_FILE")
CMD="bsub \
  -J ${JOB_NAME_Q} \
  -o ${OUTPUT_Q} \
  -q ${QUEUE} \
  -n ${TOTAL_SLOTS} \
  -R '${R_EXPR}' \
  vasp-${MARCH} \
  mpirun --display-map \
    --prtemca prte_if_include 10.1.0.0/16 \
    --prtemca plm_rsh_no_tree_spawn 1 \
    -n ${TOTAL_MPI} \
    --map-by ${MPIMAP} \
    -x OMP_NUM_THREADS=${NTHR} \
    vasp-${VASP}"
printf "\n${bold}── Submit command %s${reset}\n" "$(printf '─%.0s' {1..33})"
printf "%s\n" "$CMD"
printf "${bold}%s${reset}\n" "$(printf '─%.0s' {1..48})"
printf "
  ${bold}Enter${reset}) Submit   ${bold}e${reset}) Edit then submit   ${bold}p${reset}) Print only   ${bold}q${reset}) Quit
"
printf "Choice: "; read -r ACTION
case "$ACTION" in
  ""|s) bash -c "$CMD" ;;
  e) TMPFILE=$(mktemp /tmp/hjp_bsub_XXXXXX.sh); printf "%s\n" "$CMD">"$TMPFILE"; ${EDITOR:-vi} "$TMPFILE"; bash "$TMPFILE"; rm -f "$TMPFILE" ;;
  p) printf "%s\n" "$CMD" | tr -s ' \\n' ' '; echo ;;
  q|*) printf "Aborted.\n" ;;
esac
